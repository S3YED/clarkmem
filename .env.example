# --- LLM extractor (required: pick ONE) ------------------------------------
# Option A: Claude (native Anthropic). Auto-detected when ANTHROPIC_API_KEY is set
# and no OpenRouter key is. The cheapest capable Claude is the default.
# ANTHROPIC_API_KEY=sk-ant-...
# CLARKMEM_ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Option B: any OpenAI-compatible endpoint (OpenRouter, OpenAI, vLLM, Ollama).
OPENROUTER_API_KEY=sk-or-...
# CLARKMEM_LLM_BASE=https://openrouter.ai/api/v1
# CLARKMEM_LLM_MODEL=openai/gpt-4o-mini
# CLARKMEM_LLM_KEYENV=OPENROUTER_API_KEY      # which env var holds the key

# Force a provider explicitly (else auto-detected): openai | anthropic
# CLARKMEM_LLM_PROVIDER=anthropic

# --- backend selection ------------------------------------------------------
# local  = ChromaDB + networkx, zero external services (default)
# neo4j  = TurboVec + Neo4j, for a shared/server graph
CLARKMEM_BACKEND=local

# --- storage ----------------------------------------------------------------
# CLARKMEM_DATA_DIR=~/.clarkmem

# --- embedder (neo4j/server backend) ----------------------------------------
# st = sentence-transformers (torch), fastembed = ONNX, torch-free. Same 384d
# normalized space either way. The local backend ignores this (ChromaDB ONNX).
# CLARKMEM_EMBED_PROVIDER=fastembed

# --- ingest -----------------------------------------------------------------
# Parallel per-chunk LLM extraction (network-bound). CLI --workers overrides.
# CLARKMEM_EXTRACT_WORKERS=8

# --- HTTP server (clarkmem-serve) ---------------------------------------------
# Comma-separated to bind loopback + a VPN/tailnet IP (never use 0.0.0.0).
# CLARKMEM_HOST=127.0.0.1
# CLARKMEM_PORT=8799
# Require x-api-key on every endpoint except /health (unset = open):
# CLARKMEM_API_KEY=change-me
# Allow {"path": ...} ingestion of files under this directory ONLY (unset =
# path ingestion over HTTP is disabled; text ingestion is always available):
# CLARKMEM_INGEST_ROOT=/srv/clarkmem-inbox
# Max chars accepted in an HTTP text body (default 2,000,000):
# CLARKMEM_MAX_TEXT=2000000

# --- Neo4j (only when CLARKMEM_BACKEND=neo4j) -------------------------------
# NEO4J_URI=neo4j://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=changeme
# CLARKMEM_NEO4J_ENV_FILE=/path/to/other/.env   # optional: read creds from a file

# NOTE: legacy COGNIFY_* names for every variable above are still honored
# (pre-rename installs); CLARKMEM_* wins when both are set.
